<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <TextView
                android:id="@+id/tvNomorUrut"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="1"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/circle_bg_number"
                android:gravity="center" />
            <TextView
                android:id="@+id/tvNamaSeminar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nama Seminar"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/blue_700"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/gray_400"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Nama"
                android:textSize="12sp"
                android:textColor="@color/gray_600" />
            <TextView
                android:id="@+id/tvNamaPendaftar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/gray_800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="12sp"
                android:textColor="@color/gray_600" />
            <TextView
                android:id="@+id/tvEmailItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/gray_800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="No. HP"
                android:textSize="12sp"
                android:textColor="@color/gray_600" />
            <TextView
                android:id="@+id/tvHpItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/gray_800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Jenis Kelamin"
                android:textSize="12sp"
                android:textColor="@color/gray_600" />
            <TextView
                android:id="@+id/tvJkItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/gray_800" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTanggalDaftar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Didaftarkan: -"
            android:textSize="11sp"
            android:textColor="@color/gray_400"
            android:layout_marginTop="6dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>