<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_100">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/AppToolbar"
        app:title="Hasil Pendaftaran"
        app:subtitle="Data pendaftaran seminar kamu" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/green_50">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_check_circle"
                        android:padding="14dp"
                        app:tint="@color/green_700" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pendaftaran Berhasil!"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_700"
                    android:layout_marginTop="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data kamu telah tercatat dengan baik"
                    android:textSize="13sp"
                    android:textColor="@color/gray_600"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ringkasan Pendaftaran"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/blue_700"
                        android:layout_marginBottom="14dp" />
                    <include layout="@layout/item_result_row" android:id="@+id/rowNama"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/gray_400" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                    <include layout="@layout/item_result_row" android:id="@+id/rowEmail"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/gray_400" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                    <include layout="@layout/item_result_row" android:id="@+id/rowHp"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/gray_400" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                    <include layout="@layout/item_result_row" android:id="@+id/rowJk"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/gray_400" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                    <include layout="@layout/item_result_row" android:id="@+id/rowSeminar"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKembali"
                style="@style/ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:text="Kembali ke Beranda"
                app:icon="@drawable/ic_home"
                app:iconGravity="textStart"
                app:iconSize="18dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>